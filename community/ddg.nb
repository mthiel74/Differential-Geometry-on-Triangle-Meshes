Cell["\<\
Figure 1. Discrete Gaussian curvature on a torus from the angle defect: \
positive (warm) on the outer rim, negative (blue) on the inner rim, summing \
to zero as Gauss\[Dash]Bonnet demands.\
\>", "Text",
 CellMargins->{{70, 70}, {2, 14}},
 TextAlignment->Center,
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"d63005be-64fa-4861-9c5b-f576c48b4d85"],

Cell[TextData[{
 "The ",
 StyleBox["mean curvature",
  FontWeight->Bold],
 " comes from the cotangent Laplacian of \[Section]2 applied to the vertex \
positions (the mean-curvature normal of Meyer et al. 2003); it matches the \
smooth torus mean curvature to 3\[Times]10",
 StyleBox["\[Minus]4",
  FontSize->9],
 " and the unit sphere's ",
 StyleBox["H",
  FontSlant->Italic],
 " = 1 to 5\[Times]10",
 StyleBox["\[Minus]3",
  FontSize->9],
 "."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"1384c783-f12b-467a-92c5-93ef323b58ed"],

