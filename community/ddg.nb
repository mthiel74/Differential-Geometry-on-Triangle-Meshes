Cell["\<\
Figure 2. Discrete mean curvature on the torus, computed from the cotangent \
Laplacian of the coordinate functions.\
\>", "Text",
 CellMargins->{{70, 70}, {2, 14}},
 TextAlignment->Center,
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"670b06b9-e3fd-4274-9396-c2f7cbe4b19f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.  The cotangent Laplace\[Dash]Beltrami operator", "Section",ExpressionUUID->"2c069ebf-cd24-4db7-8c03-1186184450f9"],

Cell[TextData[{
 "The workhorse of DDG is the ",
 StyleBox["cotangent Laplacian",
  FontWeight->Bold],
 ". For a function ",
 StyleBox["f",
  FontSlant->Italic],
 " sampled at vertices,"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"3ba8cbfa-20c4-4cf1-8d94-8bf822fc0902"],

Cell[BoxData[
 TagBox[
  FormBox[
   TagBox[
    RowBox[{
     SubscriptBox[
      RowBox[{"L", " ", "f"}], "i"], "\[LongEqual]", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{
       UnderscriptBox["\[Sum]", "j"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"cot", "(", 
           SubscriptBox["\[Alpha]", "ij"], ")"}], "+", 
          RowBox[{"cot", "(", 
           SubscriptBox["\[Beta]", "ij"], ")"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["f", "j"], "-", 
          SubscriptBox["f", "i"]}], ")"}]}]}]}]}],
    HoldForm],
   TraditionalForm],
  TraditionalForm,
  Editable->True]], "DisplayFormula",
 CellMargins->{{70, Automatic}, {8, 8}},
 TextAlignment->Center,ExpressionUUID->"9e7792d3-7f72-4095-8fb9-68ca08340851"],

Cell[TextData[{
 "where ",
 StyleBox["\[Alpha]",
  FontSlant->Italic],
 " and ",
 StyleBox["\[Beta]",
  FontSlant->Italic],
 " are the two angles opposite the edge (",
 StyleBox["i",
  FontSlant->Italic],
 ",",
 StyleBox["j",
  FontSlant->Italic],
 "). It is symmetric, its row sums vanish (constants are in its kernel), and \
it is negative semi-definite \[LongDash] the discrete analogue of ",
 StyleBox["\[CapitalDelta]",
  FontSlant->Italic],
 ". Paired with the diagonal mass matrix ",
 StyleBox["M",
  FontSlant->Italic],
 " of vertex areas, it is the single operator behind every section that \
follows. In Wolfram Language it is one sparse matrix:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"b0f62c6c-83e5-4c9b-91de-02685ef51f21"],

Cell["\<\
L = DDG`cotanLaplacian[mesh];   (* V x V SparseArray *)
Max[Abs[L - Transpose[L]]]            (* 0 : symmetric *)
Max[Abs[L . ConstantArray[1., Length[L]]]]   (* ~1e-15 : constants in kernel \
*)\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"a8263266-4b53-45d4-9085-754609f115e4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.  Spectral geometry: hearing the shape of a mesh", "Section",ExpressionUUID->"d1e0018f-6fe3-4b5a-b9a9-72eeafc4ce5d"],

Cell["\<\
The eigenpairs of the Laplacian are a mesh's natural harmonics. Solving the \
generalized eigenproblem\
\>", "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"7724003d-584d-4b44-a4a8-c1bf6497fb36"],

Cell[BoxData[
 TagBox[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{"-", 
      RowBox[{"L", ".", "\[Phi]"}]}], "\[LongEqual]", 
     RowBox[{"\[Lambda]", " ", 
      RowBox[{"M", ".", "\[Phi]"}]}]}],
    HoldForm],
   TraditionalForm],
  TraditionalForm,
  Editable->True]], "DisplayFormula",
 CellMargins->{{70, Automatic}, {8, 8}},
 TextAlignment->Center,ExpressionUUID->"d6856aff-576e-435b-af82-19d80547c384"],

Cell[TextData[{
 "gives eigenvalues (a shape ",
 StyleBox["fingerprint",
  FontSlant->Italic],
 ") and eigenfunctions (smooth standing waves). On the unit sphere the \
eigenvalues must be ",
 StyleBox["l",
  FontSlant->Italic],
 "(",
 StyleBox["l",
  FontSlant->Italic],
 "+1) = 0, 2, 6, 12, 20, \[Ellipsis] with multiplicity 2",
 StyleBox["l",
  FontSlant->Italic],
 "+1 \[LongDash] and the discrete operator delivers exactly that (2.000\
\[Times]3, 5.97\[Times]5, 11.8\[Times]7), while the eigenfunctions are the \
spherical harmonics:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"5ebaa5ad-2c56-4712-a16d-db8b646fea46"],

