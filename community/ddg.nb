Cell["Animation. The same flow over time.", "Text",
 CellMargins->{{70, 70}, {2, 14}},
 TextAlignment->Center,
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"4aeb4b2e-1c09-4b0c-83e6-b44a35ae36e0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.  Outlook: geodesics and discrete exterior calculus", "Section",ExpressionUUID->"dbb6ca76-9940-4e5e-8334-8c0e9ae125c6"],

Cell[TextData[{
 "The same cotangent Laplacian computes ",
 StyleBox["geodesic distance",
  FontWeight->Bold],
 " via the heat method (Crane, Weischedel & Wardetzky 2013): diffuse heat \
briefly, normalise its gradient, then solve one Poisson problem ",
 StyleBox["L",
  FontSlant->Italic],
 StyleBox["\[Phi]",
  FontSlant->Italic],
 " = div ",
 StyleBox["X",
  FontSlant->Italic],
 ". And building the discrete exterior derivative and Hodge-star operators \
yields a ",
 StyleBox["Hodge decomposition",
  FontWeight->Bold],
 " of tangent vector fields whose harmonic part counts the surface's handles. \
Both are the next sections of this project."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"2b21ae32-a10b-42ab-94a1-e4145f05e9ab"]
}, Open  ]],

Cell[CellGroupData[{

Cell["6.  References", "Section",ExpressionUUID->"3497c8c7-9cff-4b45-8f3e-076584d80618"],

Cell[TextData[{
 "Meyer, M., Desbrun, M., Schr\[ODoubleDot]der, P., Barr, A. (2003). ",
 StyleBox["Discrete differential-geometry operators for triangulated \
2-manifolds.",
  FontSlant->Italic],
 " Visualization and Mathematics III."
}], "Text",
 CellMargins->{{60, 50}, {3, 3}},
 FontSize->11,ExpressionUUID->"f483684f-8f2b-473a-9f26-8a2a42355fc2"],

Cell[TextData[{
 "Desbrun, M., Meyer, M., Schr\[ODoubleDot]der, P., Barr, A. (1999). ",
 StyleBox["Implicit fairing of irregular meshes using diffusion and curvature \
flow.",
  FontSlant->Italic],
 " SIGGRAPH '99."
}], "Text",
 CellMargins->{{60, 50}, {3, 3}},
 FontSize->11,ExpressionUUID->"a5290054-667d-4ae9-8178-15980a487a55"],

Cell[TextData[{
 "Crane, K., Weischedel, C., Wardetzky, M. (2013). ",
 StyleBox["Geodesics in heat.",
  FontSlant->Italic],
 " ACM Transactions on Graphics. ",
 StyleBox[ButtonBox["cs.cmu.edu/~kmcrane/Projects/HeatMethod",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.cs.cmu.edu/~kmcrane/Projects/HeatMethod/"], None},
  ButtonNote->"https://www.cs.cmu.edu/~kmcrane/Projects/HeatMethod/"],
  FontColor->RGBColor[0.2, 0.3, 0.8]]
}], "Text",
 CellMargins->{{60, 50}, {3, 3}},
 FontSize->11,ExpressionUUID->"05d1bb97-f550-4fe4-b2ad-dfb6ff66459f"],

Cell[TextData[{
 "Crane, K. ",
 StyleBox["Discrete Differential Geometry: An Applied Introduction",
  FontSlant->Italic],
 " (CMU 15-458/858 course notes). ",
 StyleBox[ButtonBox["cs.cmu.edu/~kmcrane/Projects/DDG",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.cs.cmu.edu/~kmcrane/Projects/DDG/"], None},
