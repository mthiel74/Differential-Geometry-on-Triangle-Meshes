Cell[CellGroupData[{

Cell["7.  Reproducibility", "Section",ExpressionUUID->"c9a1a836-5952-4ae6-807e-7308a643fa94"],

Cell[TextData[{
 "All code is pure Wolfram Language. The shared package ",
 StyleBox["wolfram/ddg.wl",
  FontFamily->"Courier"],
 " defines the mesh accessors and operators; each section's figures are \
produced by a standalone script. Every operator is covered by a sanity check \
in ",
 StyleBox["tests/",
  FontFamily->"Courier"],
 " (Gauss\[Dash]Bonnet, mean-curvature convergence, the ",
 StyleBox["l",
  FontSlant->Italic],
 "(",
 StyleBox["l",
  FontSlant->Italic],
 "+1) spectrum, the flow rate)."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"ec7868c4-f263-4214-8516-c810c09c541f"],

Cell["\<\
wolframscript -file wolfram/curvature.wls      # \[Section]1 Gaussian curvature
wolframscript -file wolfram/meancurvature.wls  # \[Section]1-2 mean curvature
wolframscript -file wolfram/spectral.wls       # \[Section]3 spectrum + \
harmonics
wolframscript -file wolfram/meanflow.wls       # \[Section]4 mean-curvature \
flow
wolframscript -file community/build_notebook.wls   # this notebook\
\>", "Program",
 CellMargins->{{60, 30}, {6, 6}},
 ShowStringCharacters->False,
 FontFamily->"Courier",
 FontSize->11,
 Background->RGBColor[
  0.95, 0.96, 0.98],ExpressionUUID->"3f5229d9-21f8-4c3a-bd56-f1e03b74f506"]
}, Open  ]]
}, Open  ]]
},
