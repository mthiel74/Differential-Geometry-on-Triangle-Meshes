Cell[TextData[{
 "Figure 3. The first nine non-constant Laplace\[Dash]Beltrami eigenfunctions \
on a geodesic sphere \[LongDash] the discrete spherical harmonics ",
 StyleBox["Y",
  FontSlant->Italic],
 " for ",
 StyleBox["l",
  FontSlant->Italic],
 " = 1, 2, 3."
}], "Text",
 CellMargins->{{70, 70}, {2, 14}},
 TextAlignment->Center,
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"848e24f2-0ab8-488a-8a20-7ac69f4d87da"],

Cell[TextData[{
 "Truncating the eigenbasis low-pass-filters geometry, exactly as a Fourier \
series does for signals: reconstructing a bumpy mesh from its lowest ",
 StyleBox["K",
  FontSlant->Italic],
 " manifold-harmonic modes recovers progressively finer detail."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"35b0e800-2128-4bf0-9568-3e5b718c91d0"],

