Cell[TextData[{
 "Figure 4. Spectral mesh smoothing: a bumpy sphere reconstructed from its \
lowest ",
 StyleBox["K",
  FontSlant->Italic],
 " Laplacian eigenmodes \[LongDash] the geometry analogue of Fourier \
compression."
}], "Text",
 CellMargins->{{70, 70}, {2, 14}},
 TextAlignment->Center,
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"e735664c-d740-41c5-97e4-da662f161c03"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.  Mean-curvature flow: smoothing as diffusion", "Section",ExpressionUUID->"5bf1de10-3ebe-412d-82e0-c0d741441d4d"],

Cell[TextData[{
 "Letting the Laplacian pull on the vertices themselves, ",
 StyleBox["\[PartialD]",
  FontSlant->Italic],
 StyleBox["x",
  FontSlant->Italic],
 "/",
 StyleBox["\[PartialD]",
  FontSlant->Italic],
 StyleBox["t",
  FontSlant->Italic],
 " = ",
 StyleBox["\[CapitalDelta]",
  FontSlant->Italic],
 StyleBox["x",
  FontSlant->Italic],
 ", is ",
 StyleBox["mean-curvature flow",
  FontWeight->Bold],
 ": the surface diffuses, smoothing itself by its own curvature. Explicit \
time-stepping is stable only for tiny steps; the semi-implicit scheme \
(Desbrun\[Dash]Meyer\[Dash]Schr\[ODoubleDot]der\[Dash]Barr 1999) is \
unconditionally stable and is one linear solve per step:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"832ed428-5b35-4e7f-a57e-e393a97fe922"],

Cell[BoxData[
 TagBox[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"M", "-", 
        RowBox[{"\[Tau]", " ", "L"}]}], ")"}], ".", 
      TemplateBox[{"x", "\"n+1\""},
       "Superscript"]}], "\[LongEqual]", 
     RowBox[{"M", ".", 
      TemplateBox[{"x", "\"n\""},
       "Superscript"]}]}],
    HoldForm],
   TraditionalForm],
  TraditionalForm,
  Editable->True]], "DisplayFormula",
 CellMargins->{{70, Automatic}, {8, 8}},
 TextAlignment->Center,ExpressionUUID->"ac83068e-ee79-42db-a5d3-776a08a65d9b"],

Cell[TextData[{
 "As a quantitative check, a round sphere under this flow obeys ",
 StyleBox["R",
  FontSlant->Italic],
 "(",
 StyleBox["t",
  FontSlant->Italic],
 ")",
 StyleBox["\[ThinSpace]2",
  FontSize->9],
 " = ",
 StyleBox["R",
  FontSlant->Italic],
 "0",
 StyleBox["\[ThinSpace]2",
  FontSize->9],
 " \[Minus] 4",
 StyleBox["t",
  FontSlant->Italic],
 "; we recover the slope \[Minus]3.98 (theory \[Minus]4). Applied to a bumpy \
sphere \[LongDash] and rescaled to constant volume so the eye sees ",
 StyleBox["smoothing",
  FontSlant->Italic]
}], " rather than the shrinking that bare flow also produces \[LongDash] the \
surface relaxes to round and its mean curvature equalises:", \
"Text",ExpressionUUID->"63822a27-064e-475a-a480-d3a25ad21aa2"],

Cell[CellGroupData[{

Cell[BoxData[
 CellMargins -> {{50, 50}, {6, 6}}], "Input",ExpressionUUID->"330cab3e-fc8d-4f0b-a2d3-78365a80ffab"],

